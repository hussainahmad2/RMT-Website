# EmailJS — create a free account at https://www.emailjs.com
# 1. Add an Email Service (Gmail / Outlook / custom SMTP)
# 2. Create email templates that send to {{to_email}} (hr@rmt-pk.com)
# 3. Copy Service ID, Public Key, and Template IDs below

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_TEMPLATE_QUOTE=your_quote_template_id
VITE_EMAILJS_TEMPLATE_CAREER=your_career_template_id
VITE_EMAILJS_TEMPLATE_CONTACT=your_contact_template_id

# Destination inbox for quote, career, and contact form submissions
VITE_FORM_TO_EMAIL=hr@rmt-pk.com
